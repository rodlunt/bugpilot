{
  "_comment": "Master baseline for GitHub Issues conventions across all projects. Copied to .github/issue-baseline.json by /setup-issues. Each project may diverge; session-end drift check compares the project copy (not this file) against actual repo state.",
  "labels": [
    { "name": "bug",           "color": "d73a4a", "description": "Something isn't working" },
    { "name": "enhancement",   "color": "a2eeef", "description": "New feature or request" },
    { "name": "chore",         "color": "fef2c0", "description": "Cleanup, maintenance, refactor" },
    { "name": "ops",           "color": "5319e7", "description": "Operations or infrastructure" },
    { "name": "security",      "color": "ee0701", "description": "Security related" },
    { "name": "documentation", "color": "0075ca", "description": "Documentation change" },
    { "name": "discussion",    "color": "d4c5f9", "description": "Open strategic question" },
    { "name": "deferred",      "color": "e0e0e0", "description": "Non-critical; parked for later. Excluded from active backlog trays." },
    { "name": "seo",           "color": "006b75", "description": "SEO concern (rankings, indexability, schema, meta)" },
    { "name": "content",       "color": "fbca04", "description": "Content or article issue" }
  ],
  "milestones": [
    { "title": "Phase 2", "description": "Active backlog. Current focus and near-term work." },
    { "title": "Phase 3", "description": "Long-term ideas. Reviewed when Phase 2 clears." },
    { "title": "Phase 4", "description": "Nice to have. May or may not happen." }
  ],
  "vscode_queries": [
    { "label": "My Issues",                "query": "repo:{REPO} is:open is:issue assignee:${user}" },
    { "label": "All Open",                 "query": "repo:{REPO} is:open is:issue sort:updated-desc" },
    { "label": "Phase 2 (milestone)",      "query": "repo:{REPO} is:open is:issue milestone:\"Phase 2\" sort:updated-desc" },
    { "label": "Phase 3 (milestone)",      "query": "repo:{REPO} is:open is:issue milestone:\"Phase 3\" sort:updated-desc" },
    { "label": "Phase 4 (milestone)",      "query": "repo:{REPO} is:open is:issue milestone:\"Phase 4\" sort:updated-desc" },
    { "label": "Deferred",                 "query": "repo:{REPO} is:open is:issue label:deferred sort:updated-desc" },
    { "label": "Untriaged (no milestone)", "query": "repo:{REPO} is:open is:issue no:milestone -label:deferred sort:updated-desc" },
    { "label": "Bugs",                     "query": "repo:{REPO} is:open is:issue label:bug sort:updated-desc" },
    { "label": "Enhancements",             "query": "repo:{REPO} is:open is:issue label:enhancement -label:deferred sort:updated-desc" },
    { "label": "Discussion",               "query": "repo:{REPO} is:open is:issue label:discussion sort:updated-desc" },
    { "label": "SEO",                      "query": "repo:{REPO} is:open is:issue label:seo sort:updated-desc" },
    { "label": "Content",                  "query": "repo:{REPO} is:open is:issue label:content sort:updated-desc" }
  ],
  "issue_form_template": "claude-core/issue-template.yml",
  "conventions": {
    "title_style": "<type>(scope): description",
    "title_examples": [
      "feat(dashboard): add density toggle",
      "fix(social): linkedin api version bump",
      "chore(deps): update gh-action versions"
    ],
    "title_anti_patterns": [
      "Phase N: <anything> -- milestone field is the source of truth, do not duplicate in title"
    ]
  }
}
